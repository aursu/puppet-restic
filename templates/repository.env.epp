<%- | String               $repository,
      String               $password,
      Hash[String, String] $env       = {},
      Optional[String]     $cache_dir = undef,
| -%>
### MANAGED BY PUPPET (restic::repository) — repository environment (0600) ###
export RESTIC_REPOSITORY='<%= $repository %>'
export RESTIC_PASSWORD='<%= $password %>'
<% if $cache_dir { -%>
export RESTIC_CACHE_DIR='<%= $cache_dir %>'
<% } -%>
<% $env.each |$key, $value| { -%>
export <%= $key %>='<%= $value %>'
<% } -%>
